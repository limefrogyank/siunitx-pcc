{
    "compilerOptions": {
        "rootDir": "ts",
        "outDir": "js",
        "noImplicitAny": false,
        "module": "nodenext",
        "target": "es6",
        "jsx": "preserve",
        "allowJs": true,
        "sourceMap": true,
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "lib": ["ES6", "ES2020", "DOM"],
        "typeRoots": ["./node_modules/@types", "./types"],
    },
    "include": ["ts/**/*", "types/localizationResource.d.ts", "types/patch.d.ts"],
    "exclude": ["node_modules", "**/*.spec.ts", "js/**/*"],
}
